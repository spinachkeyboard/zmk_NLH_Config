/*
 * NLH Split — Physical layout and matrix transform definitions
 *
 * 15-col × 5-row matrix, 70 keys total
 * Left: cols 0–6 (7 cols), Right: cols 7–14 (8 cols)
 * Col 13 absent on left; right-most keys in ROW0/ROW2 use col 14 (1.5u BSPC/RET)
 */

#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <15>;
        rows = <5>;
        map = <
/* ROW0 (14): `  1  2  3  4  5  6  |  7  8  9  0  -  =  BSPC(1.5u) */
RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)    RC(0,7)  RC(0,8)  RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,14)
/* ROW1 (15): TAB(1.5u)  Q  W  E  R  T  Y  |  Y  U  I  O  P  [  ]  \ */
RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)    RC(1,7)  RC(1,8)  RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14)
/* ROW2 (14): CAPS(1.75u)  A  S  D  F  G  H  |  H  J  K  L  ;  '  RET(1.75u) */
RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)    RC(2,7)  RC(2,8)  RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,14)
/* ROW3 (14): LSFT(2.25u)  Z  X  C  V  B  |  B  N  M  ,  .  ?/!  UP  RSFT(1.25u) */
RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)              RC(3,7)  RC(3,8)  RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
/* ROW4 (13): Fn(1.25u)  LCTL  LALT  LGUI(1.25u)  LANG1  SPC(+15°)  |  RET(+45°)  BSPC(-15°)  RGUI(1.5u)  LANG2  ←  ↓  → */
RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)              RC(4,7)  RC(4,8) RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14)
        >;
    };
};

/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        keys /* w    h     x     y      r    rx    ry  */
            /* ROW0 Left */
            = <&key_physical_attrs 100 100    0    0   0     0    0>   /* `     */
            , <&key_physical_attrs 100 100  100    0   0     0    0>   /* 1     */
            , <&key_physical_attrs 100 100  200    0   0     0    0>   /* 2     */
            , <&key_physical_attrs 100 100  300    0   0     0    0>   /* 3     */
            , <&key_physical_attrs 100 100  400    0   0     0    0>   /* 4     */
            , <&key_physical_attrs 100 100  500    0   0     0    0>   /* 5     */
            , <&key_physical_attrs 100 100  600    0   0     0    0>   /* 6     */
            /* ROW0 Right */
            , <&key_physical_attrs 100 100 1000    0   0     0    0>   /* 7     */
            , <&key_physical_attrs 100 100 1100    0   0     0    0>   /* 8     */
            , <&key_physical_attrs 100 100 1200    0   0     0    0>   /* 9     */
            , <&key_physical_attrs 100 100 1300    0   0     0    0>   /* 0     */
            , <&key_physical_attrs 100 100 1400    0   0     0    0>   /* -     */
            , <&key_physical_attrs 100 100 1500    0   0     0    0>   /* =     */
            , <&key_physical_attrs 150 100 1600    0   0     0    0>   /* BSPC  */
            /* ROW1 Left */
            , <&key_physical_attrs 150 100    0  100   0     0    0>   /* TAB   */
            , <&key_physical_attrs 100 100  150  100   0     0    0>   /* Q     */
            , <&key_physical_attrs 100 100  250  100   0     0    0>   /* W     */
            , <&key_physical_attrs 100 100  350  100   0     0    0>   /* E     */
            , <&key_physical_attrs 100 100  450  100   0     0    0>   /* R     */
            , <&key_physical_attrs 100 100  550  100   0     0    0>   /* T     */
            , <&key_physical_attrs 100 100  650  100   0     0    0>   /* Y     */
            /* ROW1 Right */
            , <&key_physical_attrs 100 100  950  100   0     0    0>   /* Y     */
            , <&key_physical_attrs 100 100 1050  100   0     0    0>   /* U     */
            , <&key_physical_attrs 100 100 1150  100   0     0    0>   /* I     */
            , <&key_physical_attrs 100 100 1250  100   0     0    0>   /* O     */
            , <&key_physical_attrs 100 100 1350  100   0     0    0>   /* P     */
            , <&key_physical_attrs 100 100 1450  100   0     0    0>   /* [     */
            , <&key_physical_attrs 100 100 1550  100   0     0    0>   /* ]     */
            , <&key_physical_attrs 100 100 1650  100   0     0    0>   /* \     */
            /* ROW2 Left */
            , <&key_physical_attrs 175 100    0  200   0     0    0>   /* CAPS  */
            , <&key_physical_attrs 100 100  175  200   0     0    0>   /* A     */
            , <&key_physical_attrs 100 100  275  200   0     0    0>   /* S     */
            , <&key_physical_attrs 100 100  375  200   0     0    0>   /* D     */
            , <&key_physical_attrs 100 100  475  200   0     0    0>   /* F     */
            , <&key_physical_attrs 100 100  575  200   0     0    0>   /* G     */
            , <&key_physical_attrs 100 100  675  200   0     0    0>   /* H     */
            /* ROW2 Right */
            , <&key_physical_attrs 100 100  975  200   0     0    0>   /* H     */
            , <&key_physical_attrs 100 100 1075  200   0     0    0>   /* J     */
            , <&key_physical_attrs 100 100 1175  200   0     0    0>   /* K     */
            , <&key_physical_attrs 100 100 1275  200   0     0    0>   /* L     */
            , <&key_physical_attrs 100 100 1375  200   0     0    0>   /* ;     */
            , <&key_physical_attrs 100 100 1475  200   0     0    0>   /* '     */
            , <&key_physical_attrs 175 100 1575  200   0     0    0>   /* RET   */
            /* ROW3 Left */
            , <&key_physical_attrs 225 100    0  300   0     0    0>   /* LSFT  */
            , <&key_physical_attrs 100 100  225  300   0     0    0>   /* Z     */
            , <&key_physical_attrs 100 100  325  300   0     0    0>   /* X     */
            , <&key_physical_attrs 100 100  425  300   0     0    0>   /* C     */
            , <&key_physical_attrs 100 100  525  300   0     0    0>   /* V     */
            , <&key_physical_attrs 100 100  625  300   0     0    0>   /* B     */
            /* ROW3 Right */
            , <&key_physical_attrs 100 100  925  300   0     0    0>   /* B     */
            , <&key_physical_attrs 100 100 1025  300   0     0    0>   /* N     */
            , <&key_physical_attrs 100 100 1125  300   0     0    0>   /* M     */
            , <&key_physical_attrs 100 100 1225  300   0     0    0>   /* ,     */
            , <&key_physical_attrs 100 100 1325  300   0     0    0>   /* .     */
            , <&key_physical_attrs 100 100 1425  300   0     0    0>   /* ?/!   */
            , <&key_physical_attrs 100 100 1525  300   0     0    0>   /* UP    */
            , <&key_physical_attrs 125 100 1625  300   0     0    0>   /* RSFT  */
            /* ROW4 Left */
            , <&key_physical_attrs 125 100    0  400   0     0    0>   /* Fn    */
            , <&key_physical_attrs 100 100  125  400   0     0    0>   /* LCTL  */
            , <&key_physical_attrs 100 100  225  400   0     0    0>   /* LALT  */
            , <&key_physical_attrs 125 100  325  400   0     0    0>   /* LGUI  */
            , <&key_physical_attrs 100 100  550  450  1500   625   500> /* LANG1 (+15°) */
            , <&key_physical_attrs 150 100  675  500 (-4500)  725   575> /* SPC  (-45°) */
            /* ROW4 Right */
            , <&key_physical_attrs 150 100  900  500  4500   975   575> /* RET  (+45°) */
            , <&key_physical_attrs 100 100 1050  450 (-1500) 1100   500> /* BSPC (-15°) */
            , <&key_physical_attrs 150 100 1175  400   0     0    0>   /* RGUI  */
            , <&key_physical_attrs 100 100 1325  400   0     0    0>   /* LANG2 */
            , <&key_physical_attrs 100 100 1425  400   0     0    0>   /* ←    */
            , <&key_physical_attrs 100 100 1525  400   0     0    0>   /* ↓    */
            , <&key_physical_attrs 100 100 1625  400   0     0    0>   /* →    */
            ;
    };
};
